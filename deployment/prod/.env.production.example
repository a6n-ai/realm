# Production env. Copy to .env.production and fill in. Never commit .env.production.

# --- Core ---
NODE_ENV=production

# --- Database ---
# App connects THROUGH PgBouncer (transaction pooling). Host is the compose
# service name.
DATABASE_URL=postgres://USER:PASSWORD@pgbouncer:6432/tiffin
# Migrations (drizzle-kit) bypass the pooler and hit RDS directly.
DIRECT_DATABASE_URL=postgres://USER:PASSWORD@your-db.xxxxx.ca-central-1.rds.amazonaws.com:5432/tiffin

# --- PgBouncer upstream (points at RDS; same creds/host as DIRECT_DATABASE_URL) ---
PGBOUNCER_DB_HOST=your-db.xxxxx.ca-central-1.rds.amazonaws.com
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_USER=USER
PGBOUNCER_DB_PASSWORD=PASSWORD
PGBOUNCER_DB_NAME=tiffin

# --- Auth (better-auth) ---
BETTER_AUTH_URL=https://app.yourdomain.com
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32

# --- Reverse proxy / TLS (Caddy reads these) ---
DOMAIN=app.yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# --- Redis (cache L2). Compose overrides host→"redis" for the web service; this
# value is the fallback / for host-side tools. ---
REDIS_URL=redis://redis:6379

# --- Email (SES). Region-scoped; the SES client uses the instance IAM role, so
# no AWS keys here. ---
AWS_REGION=ca-central-1
NOTIFY_FROM_EMAIL=noreply@yourdomain.com
NOTIFY_FROM_NAME=Tiffin Grab
# SES_CONFIGURATION_SET=            # optional (open/click tracking, dedicated IP)

# --- File storage (S3). Set FILES_S3_BUCKET to switch off local disk. ---
FILES_S3_BUCKET=tiffin-grab-files
FILES_S3_REGION=ca-central-1
# NOTE: the current S3StorageProvider REQUIRES explicit keys (it does not yet use
# the instance IAM role like SES does). Provide keys until that code is updated,
# OR grant the bucket via an access key scoped to it. See Deploy Notes.
FILES_S3_ACCESS_KEY_ID=
FILES_S3_SECRET_ACCESS_KEY=
# FILES_S3_ENDPOINT=               # only for R2/MinIO/Backblaze; omit for AWS S3
# FILES_S3_FORCE_PATH_STYLE=true   # only for MinIO / most non-AWS endpoints
# FILES_PUBLIC_BASE_URL=/api/files # public base for file URLs (default shown)

# --- Cron endpoints shared secret ---
CRON_SECRET=change-me-random-hex

# --- Legacy (Amplify AppSync) — leave UNSET; replaced by SSE. ---
# APPSYNC_GRAPHQL_URL=
# APPSYNC_API_KEY=

# --- RabbitMQ (dedicated t2.micro broker). Unset = producer falls back to inline push. ---
RABBITMQ_URL=amqp://USER:PASSWORD@your-rabbit-host:5672
