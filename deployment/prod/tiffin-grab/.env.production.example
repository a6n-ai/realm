# Reference for what prod config exists and what each key means.
#
# You no longer copy this to .env.production — deploy.sh GENERATES that file on every
# deploy from SSM Parameter Store (/tiffin-grab/prod/<KEY>), read via the box's
# instance role. Each key below is one parameter; the value shown is a placeholder.
# To change prod config:
#   aws ssm put-parameter --region us-east-1 --overwrite \
#     --name /tiffin-grab/prod/<KEY> --type SecureString --value '<value>'
#   cd ~/realm/deployment/prod/tiffin-grab && ./deploy.sh
# Editing .env.production on the box does nothing — the next deploy overwrites it.

# --- Core ---
NODE_ENV=production
# Logger verbosity (pino → stdout → CloudWatch). Defaults to info in prod.
# Set to debug to surface dev-delivery lines (reset URLs, OTP codes) — do NOT
# run debug in prod, those would leak into CloudWatch.
LOG_LEVEL=info

# --- Database ---
# App connects THROUGH PgBouncer (transaction pooling). Host is the compose
# service name.
DATABASE_URL=postgres://USER:PASSWORD@pgbouncer:6432/tiffin
# Migrations (drizzle-kit) bypass the pooler and hit RDS directly.
DIRECT_DATABASE_URL=postgres://USER:PASSWORD@your-db.xxxxx.us-east-1.rds.amazonaws.com:5432/tiffin

# --- PgBouncer upstream (points at RDS; same creds/host as DIRECT_DATABASE_URL) ---
PGBOUNCER_DB_HOST=your-db.xxxxx.us-east-1.rds.amazonaws.com
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_USER=USER
PGBOUNCER_DB_PASSWORD=PASSWORD
PGBOUNCER_DB_NAME=tiffin

# --- Auth (better-auth) ---
BETTER_AUTH_URL=https://app.yourdomain.com
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32

# --- Reverse proxy / TLS (Caddy reads these) ---
DOMAIN=app.yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# --- Redis (cache L2). Colocated compose service — host overridden to "redis"
# for the web service; this value is the fallback / for host-side tools. ---
REDIS_URL=redis://redis:6379

# --- Email (SES). Region-scoped; the SES client uses the instance IAM role, so
# no AWS keys here. ---
AWS_REGION=us-east-1
NOTIFY_FROM_EMAIL=noreply@yourdomain.com
NOTIFY_FROM_NAME=Tiffin Grab
# SES_CONFIGURATION_SET=            # optional (open/click tracking, dedicated IP)

# --- File storage (S3). REQUIRED in prod: without FILES_S3_BUCKET the app now
# refuses to boot rather than write to the container's ephemeral disk (no volume
# is mounted, so those files die on the next deploy). ---
FILES_S3_BUCKET=tiffin-grab-files
FILES_S3_REGION=us-east-1
# Keys are for MinIO/R2 only. Leave BOTH unset on AWS: the S3 client then uses the
# instance IAM role, same as SES above. Setting only one is treated as unset.
# FILES_S3_ACCESS_KEY_ID=
# FILES_S3_SECRET_ACCESS_KEY=
# FILES_S3_ENDPOINT=               # only for R2/MinIO/Backblaze; omit for AWS S3
# FILES_S3_FORCE_PATH_STYLE=true   # only for MinIO / most non-AWS endpoints
# FILES_PUBLIC_BASE_URL=/api/files # public base for file URLs (default shown)

# --- Cron endpoints shared secret ---
CRON_SECRET=change-me-random-hex

# --- Legacy (Amplify AppSync) — leave UNSET; replaced by SSE. ---
# APPSYNC_GRAPHQL_URL=
# APPSYNC_API_KEY=

# --- RabbitMQ (dedicated t2.micro broker). Unset = producer falls back to inline push. ---
RABBITMQ_URL=amqp://USER:PASSWORD@your-rabbit-host:5672
