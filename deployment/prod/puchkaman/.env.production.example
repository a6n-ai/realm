# Reference for prod config. You do NOT copy this to .env.production — deploy.sh
# GENERATES that file on every deploy from SSM Parameter Store (/puchkaman/prod/<KEY>),
# read via Box B's instance role. To change prod config:
#   aws ssm put-parameter --region us-east-1 --overwrite \
#     --name /puchkaman/prod/<KEY> --type SecureString --value '<value>'
#   cd ~/realm/deployment/prod/puchkaman && ./deploy.sh

# --- Core ---
NODE_ENV=production
LOG_LEVEL=info

# --- Database ---
# App connects THROUGH pgbouncer (transaction pooling). Host is the compose service name.
DATABASE_URL=postgres://USER:PASSWORD@pgbouncer:6432/puchkaman
# Migrations (drizzle-kit) bypass the pooler and hit RDS directly. MUST end ?sslmode=no-verify.
DIRECT_DATABASE_URL=postgres://USER:PASSWORD@puchkaman-prod.xxxxx.us-east-1.rds.amazonaws.com:5432/puchkaman?sslmode=no-verify

# --- PgBouncer upstream (points at the puchkaman RDS) ---
PGBOUNCER_DB_HOST=puchkaman-prod.xxxxx.us-east-1.rds.amazonaws.com
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_USER=USER
PGBOUNCER_DB_PASSWORD=PASSWORD
PGBOUNCER_DB_NAME=puchkaman

# --- Auth (better-auth). Leave NEXT_PUBLIC_BETTER_AUTH_URL UNSET (same-origin fallback). ---
BETTER_AUTH_URL=https://puchkaman.ca
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32

# --- Reverse proxy / TLS (Box B Caddy reads ACME_EMAIL) ---
ACME_EMAIL=ops@yourdomain.com

# --- File storage (S3). Instance role provides creds — leave keys UNSET on AWS. ---
AWS_REGION=us-east-1
FILES_S3_BUCKET=puchkaman-files-<acct>-us-east-1-an
FILES_S3_REGION=us-east-1
