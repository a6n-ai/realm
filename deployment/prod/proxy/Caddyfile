{
	# ACME account email for Let's Encrypt (auto-TLS). Set ACME_EMAIL in .env.production.
	email {$ACME_EMAIL}
}

# --- tiffin-grab --- $TG_DOMAIN from proxy/.env.production. Caddy auto-issues + renews.
{$TG_DOMAIN} {
	encode zstd gzip

	# SSE — stream events immediately, no response buffering.
	@sse path /api/notifications/stream
	reverse_proxy @sse tiffin-grab-web:3000 {
		flush_interval -1
	}

	reverse_proxy tiffin-grab-web:3000
}

# --- puchkaman --- public marketing site (no DB/SSE). www → apex handled by Caddy.
puchkaman.ca, www.puchkaman.ca {
	encode zstd gzip
	reverse_proxy puchkaman-web:3000
}
