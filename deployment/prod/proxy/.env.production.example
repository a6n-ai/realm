# Shared Caddy ingress env. Copy to .env.production in this folder. Never commit it.
# Caddy reads these to issue certs and name the tiffin-grab vhost.

# ACME account email for Let's Encrypt.
ACME_EMAIL=ops@yourdomain.com

# tiffin-grab's public domain (the puchkaman.ca hosts are literals in the Caddyfile).
TG_DOMAIN=app.yourdomain.com
